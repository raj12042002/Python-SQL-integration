# Step 3: Extract Data

```python
from bs4 import BeautifulSoup
import requests

url = "https://quotes.toscrape.com"

response = requests.get(url)

soup = BeautifulSoup(
    response.text,
    "html.parser"
)

quotes = soup.find_all(
    "span",
    class_="text"
)

for quote in quotes:
    print(quote.text)
```

---

# Step 4: Store Data in CSV

```python
import csv
from bs4 import BeautifulSoup
import requests

url = "https://quotes.toscrape.com"

response = requests.get(url)

soup = BeautifulSoup(
    response.text,
    "html.parser"
)

quotes = soup.find_all(
    "span",
    class_="text"
)

with open(
    "quotes.csv",
    "w",
    newline="",
    encoding="utf-8"
) as file:

    writer = csv.writer(file)

    writer.writerow(["Quote"])

    for quote in quotes:
        writer.writerow([quote.text])

print("Data Saved")
```

