# Complete Scraper Project

```python
import requests
from bs4 import BeautifulSoup
import sqlite3

conn = sqlite3.connect(
    "quotes.db"
)

cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS quotes(
id INTEGER PRIMARY KEY,
quote TEXT
)
""")

url = "https://quotes.toscrape.com"

response = requests.get(url)

soup = BeautifulSoup(
    response.text,
    "html.parser"
)

quotes = soup.find_all(
    "span",
    class_="text"
)

for quote in quotes:

    cursor.execute("""
    INSERT INTO quotes(quote)
    VALUES(?)
    """,(quote.text,))

conn.commit()

print("Quotes Saved Successfully")
```

